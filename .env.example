SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
SUPABASE_TABLE=app_state
CRON_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_VALUE
ALMADAN_APP_URL=https://almadan.vercel.app
OCR_SPACE_API_KEY=YOUR_OCR_SPACE_API_KEY
VAPID_PUBLIC_KEY=YOUR_URL_SAFE_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_BASE64_DER_PRIVATE_KEY
VAPID_SUBJECT=mailto:YOUR_EMAIL@example.com

# WhatsApp Cloud API (Meta) -- business-initiated mesajlar icin onceden
# Meta'da onaylanmis sablon adlari (kategori: Utility) gerekir.
WHATSAPP_ACCESS_TOKEN=YOUR_META_ACCESS_TOKEN
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_WELCOME_TEMPLATE_NAME=welcome
WHATSAPP_CAMPAIGN_TEMPLATE_NAME=campaign_alert
WHATSAPP_FOLLOW_TEMPLATE_NAME=store_follow_confirm

# Netgsm SMS -- serbest metin, sablon onayi gerektirmez. Panelden alinan
# kullanici kodu/sifre/mesaj basligi (msgheader).
NETGSM_USERCODE=YOUR_NETGSM_USERCODE
NETGSM_PASSWORD=YOUR_NETGSM_PASSWORD
NETGSM_MSGHEADER=YOUR_APPROVED_SENDER_ID

# AI & Scraper APIs
REPLICATE_API_TOKEN=YOUR_REPLICATE_API_TOKEN
AI_WEBHOOK_SECRET=YOUR_AI_WEBHOOK_SECRET
CACHE_TTL_HOURS=6
CHAOS_ENABLED=false
RAILWAY_SCRAPER_URL=https://your-railway-scraper.up.railway.app
SCRAPER_SECRET=YOUR_SCRAPER_SECRET
ADMIN_DEBUG_SECRET=YOUR_ADMIN_DEBUG_SECRET
GO_UPC_API_KEY=YOUR_GO_UPC_API_KEY

# Google Sheets Sync
GOOGLE_SERVICE_ACCOUNT_JSON=YOUR_GOOGLE_SERVICE_ACCOUNT_JSON
GOOGLE_SHEET_ID=YOUR_GOOGLE_SHEET_ID
