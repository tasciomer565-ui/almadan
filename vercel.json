{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "fastapi",
  "regions": [
    "fra1"
  ],
  "functions": {
    "app/main.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/static/index.html" },
    { "source": "/index.html", "destination": "/static/index.html" },
    { "source": "/hakkinda", "destination": "/static/hakkinda.html" },
    { "source": "/gizlilik", "destination": "/static/gizlilik.html" },
    { "source": "/iletisim", "destination": "/static/iletisim.html" }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Vary", "value": "*" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/cron/refresh-all",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/cron/store-newsletters",
      "schedule": "0 6 * * *"
    }
  ]
}
