{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "fastapi",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/cron/refresh-all",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/ai/worker",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/cron/catalog-scan",
      "schedule": "0 6 * * 1,4"
    },
    {
      "path": "/cron/weekly-digest",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/cron/semantic-index",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/cron/group-buy-expire",
      "schedule": "0 * * * *"
    },
    {
      "path": "/cron/cleanup-metrics",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/cron/check-reminders",
      "schedule": "0 8 * * *"
    }
  ]
}
