{
  "manifest_version": 3,
  "name": "Almadan Akıllı Asistan",
  "version": "1.1",
  "description": "Alışveriş yaparken aynı ürünü başka nerede daha ucuza alabileceğinizi gösterir.",
  "permissions": ["activeTab"],
  "host_permissions": [
    "*://*.trendyol.com/*",
    "*://*.hepsiburada.com/*",
    "*://*.amazon.com.tr/*",
    "https://www.almadan.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.trendyol.com/*",
        "*://*.hepsiburada.com/*",
        "*://*.amazon.com.tr/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}
